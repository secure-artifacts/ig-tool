{
  "name": "ig-tool",
  "description": "ig-tool",
  "private": false,
  "version": "0.0.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "serve": "run-s dev:*",
    "dev:clear": "rimraf dist",
    "dev:web": "cross-env NODE_ENV=development vite",
    "build": "run-s build:*",
    "build:clear": "rimraf dist",
    "build:logo": "esno scripts/logoBuild.ts",
    "build:web": "cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "checkUpdate": "cross-env NPM_CHECK_INSTALLER=pnpm npm-check -u -i",
    "typecheck": "tsc -p tsconfig.json",
    "format": "npx prettier --write \"**/*.{js,mjs,cjs,ts,tsx,jsx,json}\"",
    "postinstall": "npm run build:logo",
    "pack": "esno ./scripts/packDist.ts"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.2.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@webextkits/messages-center": "^1.0.1",
    "@webextkits/storage-local": "^1.0.0",
    "@webextkits/vite-plugins": "^1.1.4",
    "archiver": "^7.0.1",
    "antd": "^6.0.0",
    "cross-env": "^10.1.0",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.2",
    "get-port": "^7.1.0",
    "icon-gen": "^5.0.0",
    "less": "^4.4.2",
    "lodash-es": "^4.17.21",
    "npm-check": "^6.0.1",
    "@types/chrome": "^0.1.27",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.1"
  }
}
